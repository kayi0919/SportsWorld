<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/start_background"
    tools:context=".start">

    <ImageView
        android:id="@+id/start_3"
        android:layout_width="321dp"
        android:layout_height="53dp"
        android:layout_marginStart="45dp"
        android:layout_marginTop="155dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/start_3" />

    <ImageView
        android:id="@+id/start_1"
        android:layout_width="38dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/start_1" />

    <ImageView
        android:id="@+id/start_2"
        android:layout_width="148dp"
        android:layout_height="22dp"
        android:layout_marginStart="208dp"
        android:layout_marginTop="28dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/start_2" />

    <Button
        android:id="@+id/start"
        android:layout_width="171dp"
        android:layout_height="53dp"
        android:layout_marginStart="120dp"
        android:layout_marginTop="448dp"
        android:background="@drawable/button_c99427"
        android:text="@string/start"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/start_3"  />

</androidx.constraintlayout.widget.ConstraintLayout>

